APP_NAME=Bot Simulator Worker
APP_VERSION=3.0.0
ENVIRONMENT=development
SIMULATOR_WORKER_HOST=0.0.0.0
SIMULATOR_WORKER_PORT=8007
BOT_API_KEY=change-me
USERS_STORAGE_DIR=../bot_auth_worker/Users
SIMULATOR_HISTORY_FILE=SimulatorHistory.json
WS_PRICE_PATH=/xag/ws/xag/price/
PRICE_WS_SYMBOL=xag
PRICE_WS_SUBSCRIBE_MESSAGE={"action":"SubAdd","subs":["0~hivagold~xag~gold"]}
HELPER_WS_URL=ws://localhost:8010/ws/price
HELPER_SYMBOL=xag
HELPER_CANDLE_MOVE_THRESHOLD=1.5
ORDER_TOLERANCE_MAX=5
STOP_TOLERANCE_MAX=2
BARS_API_PATH=/xag/api/xag-bars/
